# ==============================================================
# ShieldPlate 电商平台 - 环境变量模板
# 复制此文件为 .env 并填入实际值
# 警告：.env 文件包含敏感信息，绝不可提交到版本控制
# ==============================================================

# -------------------- 数据库配置 --------------------
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=          # 必填：数据库密码，生产环境请使用强密码
POSTGRES_DB=ecommerce
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -------------------- Redis 配置 --------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=             # 可选：Redis 密码，生产环境建议设置
REDIS_DB=0

# -------------------- 后端应用配置 --------------------
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -------------------- 安全配置 --------------------
SECRET_KEY=                 # 必填：JWT 签名密钥，生产环境必须使用随机强密钥
                            # 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -------------------- CORS 配置 --------------------
CORS_ORIGINS=http://localhost:3876,http://localhost:5173

# -------------------- 前端构建配置 --------------------
VITE_API_BASE_URL=          # 可选：前端 API 地址，开发环境留空走 Vite 代理

# -------------------- 端口映射 --------------------
API_PORT=8876
WEB_PORT=3876
DB_PORT=5876
REDIS_PORT_MAPPING=6876
